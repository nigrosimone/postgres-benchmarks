{
  "name": "postgres-benchmarks",
  "version": "1.0.0",
  "description": "A benchmark focusing on the performance of Postgres client libraries for Node.js, brianc/node-postgres VS porsager/postgres",
  "keywords": [
    "nodejs",
    "javascript",
    "benchmark",
    "postgresql",
    "node-js",
    "pg",
    "postgres",
    "pg-native",
    "node",
    "postgres.js"
  ],
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "bench": "node --expose-gc index.ts",
    "docker-build": "docker-compose build",
    "docker-up": "docker-compose up"
  },
  "author": "Simone Nigro",
  "license": "ISC",
  "dependencies": {
    "@sixfold/fast-postgres-date-parser": "^0.0.6",
    "pg": "8.22.0",
    "pg-native": "3.8.0",
    "postgres": "3.4.9",
    "tinybench": "6.0.2"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "allowScripts": {
    "libpq": true
  }
}
